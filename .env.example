# Comment-Vision-Claw Configuration
# Copy this file to .env and modify as needed

# Data directories
DATA_DIR=./data
SCREENSHOTS_DIR=./data/screenshots
USER_DATA_DIR=./data/user_data

# Platform settings
PLATFORM=douyin

# Browser settings
# Set to 'true' to show browser UI, 'false' for headless mode
HEADLESS=false

# Hot comment thresholds (OR condition: likes >= MIN_LIKE_COUNT OR replies >= MIN_REPLY_COUNT)
MIN_LIKE_COUNT=5000
MIN_REPLY_COUNT=400

# Max videos to crawl
MAX_VIDEOS=200
# Max comments in report
MAX_COMMENTS=10
# Max screenshots to capture
MAX_SCREENSHOTS=10

# External tools
# Path to MediaCrawler (relative or absolute)
MEDIACRAWLER_PATH=../MediaCrawler

# Chrome DevTools Protocol URL (for screenshots)
CDP_URL=http://127.0.0.1:9222

# AI Analysis (Optional)
# Leave empty to use keyword-based analysis
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
