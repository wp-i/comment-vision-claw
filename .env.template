# Comment-Vision-Claw 环境配置
# 复制此文件为 .env 并修改配置

# ==================== 基础配置 ====================
# 数据存储目录
DATA_DIR=./data
SCREENSHOTS_DIR=./data/screenshots
USER_DATA_DIR=./data/user_data

# 平台配置（目前仅支持 douyin）
PLATFORM=douyin

# 浏览器模式（true=无头模式，false=显示浏览器）
HEADLESS=false

# ==================== 热评筛选配置 ====================
# 最小点赞数阈值（OR 条件）
# 只有点赞数 >= 此值 或 回复数 >= MIN_REPLY_COUNT 的评论才会被捕获
MIN_LIKE_COUNT=5000

# 最小回复数阈值（OR 条件）
MIN_REPLY_COUNT=500

# 最大抓取视频数（降低此值可减少被封风险）
MAX_VIDEOS=100

# 最大热评数
MAX_COMMENTS=10

# 最大截图数
MAX_SCREENSHOTS=10

# ==================== MediaCrawler 配置 ====================
# MediaCrawler 安装路径
# Windows: D:\MediaCrawler
# macOS/Linux: /path/to/MediaCrawler
MEDIACRAWLER_PATH=D:\MediaCrawler

# ==================== AI 分析配置（可选） ====================
# 配置后，分析报告将使用 AI 生成更精准的内容
# 留空则使用关键词匹配分析

# OpenAI API Key（或兼容 API 的 Key）
OPENAI_API_KEY=

# API Base URL（支持其他兼容服务）
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# 智谱: https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# DeepSeek: deepseek-chat
# 智谱: glm-4-flash
OPENAI_MODEL=gpt-4o-mini

# ==================== 高级配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
